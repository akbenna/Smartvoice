# =============================================================================
# PRODUCTIE — Railway Environment Variables
# =============================================================================
# Stel deze in via Railway Dashboard > Variables (NIET in dit bestand!)
# Dit bestand dient alleen als referentie.
# =============================================================================

# --- Algemeen ---
APP_ENV=production
APP_LOG_LEVEL=WARNING
APP_SECRET_KEY=       # Genereer: openssl rand -hex 32

# --- Database (Railway PostgreSQL plugin) ---
# Railway vult DATABASE_URL automatisch in. Handmatig:
POSTGRES_HOST=        # Railway geeft dit automatisch
POSTGRES_PORT=5432
POSTGRES_DB=consultassistent
POSTGRES_USER=ca_app
POSTGRES_PASSWORD=    # Railway genereert dit
DB_ENCRYPTION_KEY=    # Genereer: openssl rand -hex 32

# --- Redis (Railway Redis plugin) ---
REDIS_HOST=           # Railway geeft dit automatisch
REDIS_PORT=6379
REDIS_PASSWORD=       # Railway genereert dit

# --- Ollama (extern — GPU server of cloud) ---
# Optie 1: Eigen GPU server
OLLAMA_HOST=https://jouw-gpu-server.example.com:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# Optie 2: Cloud LLM API (Mistral/Claude)
CLOUD_FALLBACK_ENABLED=false
CLOUD_FALLBACK_PROVIDER=mistral
CLOUD_FALLBACK_API_KEY=
CLOUD_FALLBACK_API_URL=https://api.mistral.ai/v1

# --- Whisper (extern — GPU server of cloud API) ---
# Als je cloud STT gebruikt (Deepgram/OpenAI), configureer in extraction service
WHISPER_DEVICE=cpu
WHISPER_MODEL=large-v3-turbo

# --- Audio ---
AUDIO_STORAGE_PATH=/data/audio
AUDIO_MAX_DURATION_SECONDS=3600

# --- HIS Export ---
HIS_DEFAULT_TARGET=clipboard
CGM_API_URL=
CGM_API_KEY=
MEDICOM_API_URL=
MEDICOM_API_KEY=

# --- Beveiliging ---
CORS_ALLOWED_ORIGINS=https://smartvoice-nine.vercel.app
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5

# --- Audit ---
AUDIT_LOG_RETENTION_YEARS=5
