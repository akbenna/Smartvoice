# =============================================================================
# AI-Consultassistent — Development (macOS)
# =============================================================================
# Kopieer naar .env: cp .env.dev .env
# =============================================================================

# --- Algemeen ---
APP_ENV=development
APP_LOG_LEVEL=DEBUG

# --- Database (Docker container) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=consultassistent
POSTGRES_USER=ca_app
POSTGRES_PASSWORD=devpassword

# --- Redis (Docker container) ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=devredis

# --- Whisper STT (CPU op Mac — trager maar werkt) ---
WHISPER_MODEL=large-v3-turbo
WHISPER_MODEL_PATH=./data/models/whisper
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=nl
WHISPER_BEAM_SIZE=5

# --- Diarisatie (optioneel — vereist HuggingFace token) ---
DIARIZATION_ENABLED=false
HF_TOKEN=

# --- Ollama (draait native op macOS via ollama.com) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# --- Cloud Fallback (UIT) ---
CLOUD_FALLBACK_ENABLED=false

# --- Audio ---
AUDIO_STORAGE_PATH=./data/audio

# --- Beveiliging ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_TIMEOUT_MINUTES=60
