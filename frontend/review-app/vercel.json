{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["cdg1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://$BACKEND_URL/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://$BACKEND_URL/health"
    }
  ]
}
