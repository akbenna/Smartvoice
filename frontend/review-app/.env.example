# =============================================================================
# AI-Consultassistent — Frontend Environment Variables
# =============================================================================
# Kopieer dit bestand naar .env.local en pas de waarden aan.

# Backend API URL (de GPU-server in de praktijk)
# Lokaal: http://localhost:8000
# Productie: https://jouw-server.example.com (vast IP of VPN)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend URL voor server-side rewrites (Vercel)
# Wordt gebruikt door next.config.js rewrites — niet zichtbaar voor de browser
BACKEND_URL=http://localhost:8000

# App naam (optioneel)
NEXT_PUBLIC_APP_NAME=AI-Consultassistent
